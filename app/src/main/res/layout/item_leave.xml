<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="5dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E8EDF2"
    app:rippleColor="#1A1565C0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white">

        <!-- ── Colored Top Accent Bar (dynamic via adapter) ── -->
        <View
            android:id="@+id/viewAccent"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:visibility="gone"
            android:background="#1565C0" />

        <!-- ── Main Content ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Row 1: Date Range + Status + Arrow -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Date + Duration -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDateRange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="07 Jan – 09 Jan 2026"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:letterSpacing="0.01" />

                    <TextView
                        android:id="@+id/tvDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 days"
                        android:textSize="11sp"
                        android:textColor="#9E9E9E"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Status Badge -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PENDING"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:textColor="#EF6C00"
                    android:layout_marginStart="8dp" />

                <!-- Forward Arrow -->
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:alpha="0.35"
                    app:tint="#607D8B"
                    android:contentDescription="View details" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F4F8"
                android:layout_marginVertical="12dp" />

            <!-- Row 2: Leave Type + Paid Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Leave type icon -->
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="6dp"
                    android:src="@drawable/leaveee"
                    app:tint="#78909C"
                    android:contentDescription="Leave type" />

                <TextView
                    android:id="@+id/tvType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Casual Leave"
                    android:textSize="13sp"
                    android:textColor="#455A64"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <!-- Paid Badge -->
                <TextView
                    android:id="@+id/chipPaid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="9dp"
                    android:paddingVertical="3dp"
                    android:text="PAID"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:background="@drawable/badge_paid"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Row 3: Applied Date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="#BDBDBD"
                    android:contentDescription="Applied date" />

                <TextView
                    android:id="@+id/tvAppliedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Applied on 05 Jan 2026"
                    android:textSize="11sp"
                    android:textColor="#BDBDBD"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Row 4: Rejection Reason (Conditional) -->
            <LinearLayout
                android:id="@+id/layoutReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#FFEBEE"
                android:padding="10dp"
                android:layout_marginTop="10dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="7dp"
                    android:src="@drawable/ic_info"
                    app:tint="#D32F2F"
                    android:contentDescription="Rejection reason" />

                <TextView
                    android:id="@+id/tvReason"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rejected: Family emergency not approved"
                    android:textSize="12sp"
                    android:textColor="#D32F2F"
                    android:lineSpacingExtra="2dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>